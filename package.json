{
  "name": "zoneweaver",
  "version": "0.9.0",
  "description": "Zoneweaver API - NodeJS backend and Vite based frontend",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "sync-versions": "node scripts/sync-versions.js",
    "generate-docs": "node scripts/generate-docs.js",
    "prebuild": "npm run sync-versions",
    "build": "cd web && npm run build",
    "start": "npm run build && node index.js",
    "dev": "npm run build && nodemon index.js",
    "local-api": "nodemon index.js",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:fix": "npm run lint:backend:fix && npm run lint:frontend:fix",
    "lint:backend": "eslint . --ignore-pattern 'web/**'",
    "lint:backend:fix": "eslint . --fix --ignore-pattern 'web/**'",
    "lint:frontend": "cd web && npm run lint",
    "lint:frontend:fix": "cd web && npm run lint:fix",
    "lint:all": "npm run lint",
    "lint:fix:all": "npm run lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "bhyve",
    "react",
    "nodejs"
  ],
  "author": "Makr91",
  "license": "GPL-3.0",
  "dependencies": {
    "@sequelize/core": "^7.0.0-alpha.46",
    "@sequelize/mariadb": "^7.0.0-alpha.46",
    "@sequelize/mysql": "^7.0.0-alpha.46",
    "@sequelize/postgres": "^7.0.0-alpha.46",
    "@sequelize/sqlite3": "^7.0.0-alpha.46",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.17.3",
    "jsonwebtoken": "^9.0.2",
    "ldapts": "^8.1.8",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.2",
    "nodemon": "^3.1.9",
    "openid-client": "^6.7.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "passport-oauth2": "^1.8.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.17.1",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "tar": "^7.4.3",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^17.7.0",
    "prettier": "^3.6.2"
  }
}
